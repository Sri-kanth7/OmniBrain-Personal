# ==========================================================
# OmniBrain - Production .gitignore
# ==========================================================

# ==========================================================
# Python
# ==========================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# ==========================================================
# Virtual Environments
# ==========================================================
.venv/
venv/
env/
ENV/
.python-version

# ==========================================================
# Environment Variables
# ==========================================================
.env
.env.*
!.env.example

# ==========================================================
# IDE / Editors
# ==========================================================
.vscode/
.idea/
*.code-workspace

# ==========================================================
# Jupyter / Google Colab
# ==========================================================
.ipynb_checkpoints/
*.ipynb

# ==========================================================
# Testing / Coverage
# ==========================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ==========================================================
# Static Analysis
# ==========================================================
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# ==========================================================
# Build / Packaging
# ==========================================================
build/
dist/
.eggs/
*.egg-info/
pip-wheel-metadata/

# ==========================================================
# Logs
# ==========================================================
logs/*
*.log
!logs/.gitkeep

# ==========================================================
# Temporary Files
# ==========================================================
tmp/
temp/
*.tmp
*.bak
*.swp
*.swo
*~

# ==========================================================
# Operating System
# ==========================================================
.DS_Store
Thumbs.db
desktop.ini

# ==========================================================
# Hugging Face / Torch Cache
# ==========================================================
.cache/
huggingface/
.cache/huggingface/
.cache/torch/
.cache/transformers/
.cache/sentence_transformers/

# ==========================================================
# OCR Cache
# ==========================================================
.easyocr/

# ==========================================================
# Runtime Models
# ==========================================================
*.pt
*.pth
*.ckpt
*.onnx
*.safetensors

# ==========================================================
# Local Databases
# ==========================================================
*.sqlite
*.sqlite3
*.db

# ==========================================================
# Runtime Outputs
# ==========================================================

# Processed pipeline outputs
data/processed/*
!data/processed/.gitkeep

# Local embedded Qdrant
data/vector_db/*
!data/vector_db/.gitkeep

# Temporary files
data/temp/*
!data/temp/.gitkeep

# ==========================================================
# Input PDFs
# Keep folder but ignore actual PDFs
# ==========================================================
data/input/pdfs/*
!data/input/pdfs/.gitkeep

# ==========================================================
# Exported Vector Dumps
# ==========================================================
omnibrain_text_vectors.json
omnibrain_image_vectors.json

# ==========================================================
# Generated Reports
# ==========================================================
architecture.txt

# ==========================================================
# Archives
# ==========================================================
*.zip
*.rar
*.7z
*.tar
*.gz

# ==========================================================
# Runtime
# ==========================================================
*.pid
*.seed

# ==========================================================
# Keep Important Files
# ==========================================================
!README.md
!requirements.txt
!pyproject.toml